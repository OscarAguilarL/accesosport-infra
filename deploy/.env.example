# ── ECR ──────────────────────────────────────────────────────────────────────
# Obtener de: terraform output ecr_backend_url / ecr_frontend_url
ECR_REGISTRY=<ACCOUNT_ID>.dkr.ecr.us-east-1.amazonaws.com
ECR_BACKEND_REPO=accesosport-backend
ECR_FRONTEND_REPO=accesosport-frontend

# ── Image tags ────────────────────────────────────────────────────────────────
# El CD pipeline los actualiza automáticamente al hacer deploy
BACKEND_IMAGE_TAG=latest
FRONTEND_IMAGE_TAG=latest
BACKEND_STAGING_IMAGE_TAG=latest
FRONTEND_STAGING_IMAGE_TAG=latest

# ── Base de datos ─────────────────────────────────────────────────────────────
DB_USERNAME=accesosport
DB_PASSWORD=<CAMBIAR_POR_PASSWORD_SEGURA>
DB_NAME_PROD=accesosport_prod
DB_NAME_STAGING=accesosport_staging

# ── JWT ───────────────────────────────────────────────────────────────────────
APP_JWT_SECRET=<STRING_ALEATORIO_MIN_32_CHARS>
APP_JWT_SECRET_STAGING=<STRING_ALEATORIO_DISTINTO_MIN_32_CHARS>

# ── URLs de la aplicación ─────────────────────────────────────────────────────
APP_FRONTEND_URL=https://accesosport.com
APP_CORS_ALLOWED_ORIGINS=https://accesosport.com,https://www.accesosport.com
APP_FRONTEND_URL_STAGING=https://staging.accesosport.com
APP_CORS_ALLOWED_ORIGINS_STAGING=https://staging.accesosport.com

# ── Admin bootstrap ───────────────────────────────────────────────────────────
APP_ADMIN_PASSWORD=<PASSWORD_SEGURA_PARA_ADMIN>

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=<TU_CLOUD_NAME>
CLOUDINARY_API_KEY=<TU_API_KEY>
CLOUDINARY_API_SECRET=<TU_API_SECRET>

# ── Resend ────────────────────────────────────────────────────────────────────
RESEND_API_KEY=<TU_RESEND_API_KEY>

# ── Stripe (producción) ───────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_<TU_KEY>
STRIPE_WEBHOOK_SECRET=whsec_<TU_SECRET>
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_<TU_CONNECT_SECRET>

# ── Stripe (staging — usar keys de test) ──────────────────────────────────────
STRIPE_SECRET_KEY_STAGING=sk_test_<TU_KEY>
STRIPE_WEBHOOK_SECRET_STAGING=whsec_<TU_SECRET_TEST>
STRIPE_CONNECT_WEBHOOK_SECRET_STAGING=whsec_<TU_CONNECT_SECRET_TEST>

# ── S3 Backups ────────────────────────────────────────────────────────────────
S3_BACKUP_BUCKET=accesosport-db-backups
